-- ── INPUT BOX BUILDER ────────────────────────────────────────────────────────
local function InputBox(parent, placeholder, height, order, isMultiline)
    local wrap = Instance.new("Frame")
    wrap.Size             = UDim2.new(1, 0, 0, height)
    wrap.BackgroundColor3 = C.BG0
    wrap.BorderSizePixel  = 0
    wrap.LayoutOrder      = order
    wrap.Parent           = parent
    Corner(wrap, 8)
    local stroke = Stroke(wrap, C.BORDER, 1)

    local box = Instance.new("TextBox")
    box.Size               = UDim2.new(1, -20, 1, -10)
    box.Position           = UDim2.new(0, 10, 0, 5)
    box.BackgroundTransparency = 1
    box.TextColor3         = C.TXT0
    box.PlaceholderColor3  = C.TXT2
    box.PlaceholderText    = placeholder
    box.Font               = Enum.Font.Gotham
    box.TextScaled         = true
    box.TextWrapped        = true
    box.MultiLine          = isMultiline or false
    box.ClearTextOnFocus   = false
    box.BorderSizePixel    = 0
    box.ZIndex             = 13
    box.Parent             = wrap

    box.Focused:Connect(function()
        Tween(stroke, 0.15, {Color = C.ACC1, Thickness = 1.5}):Play()
        Tween(wrap, 0.15, {BackgroundColor3 = C.BG1}):Play()
    end)
    box.FocusLost:Connect(function()
        Tween(stroke, 0.15, {Color = C.BORDER, Thickness = 1}):Play()
        Tween(wrap, 0.15, {BackgroundColor3 = C.BG0}):Play()
    end)

    return box, wrap
end

-- ── CHIP ROW BUILDER ─────────────────────────────────────────────────────────
local function ChipRow(parent, options, default, order)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, 34)
    row.BackgroundTransparency = 1
    row.LayoutOrder      = order
    row.Parent           = parent
    local rl = Instance.new("UIListLayout", row)
    rl.FillDirection = Enum.FillDirection.Horizontal
    rl.Padding        = UDim.new(0, 6)

    local selected = default
    local btns = {}

    for _, val in ipairs(options) do
        local isActive = val == default
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, 0, 1, 0)
        btn.AutomaticSize    = Enum.AutomaticSize.X
        btn.BackgroundColor3 = isActive and C.ACC1 or C.BG3
        btn.TextColor3       = isActive and C.TXT0 or C.TXT2
        btn.Font             = Enum.Font.GothamBold
        btn.Text             = "  "..tostring(val).."  "
        btn.TextScaled       = true
        btn.BorderSizePixel  = 0
        btn.AutoButtonColor  = false
        btn.ZIndex           = 13
        btn.Parent           = row
        Corner(btn, 8)

        btns[val] = btn

        btn.MouseButton1Click:Connect(function()
            selected = val
            for v, b in pairs(btns) do
                local active = v == val
                Tween(b, 0.12, {
                    BackgroundColor3 = active and C.ACC1 or C.BG3,
                    TextColor3       = active and C.TXT0 or C.TXT2,
                }):Play()
            end
        end)
    end

    return row, function() return selected end
end

