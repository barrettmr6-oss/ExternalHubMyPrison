local function GenerateRap(key,desc,n,cb)
    local req=(syn and syn.request)or(http and http.request)or request or nil
    if not req then cb(nil,"Executor HTTP not supported");return end
    if not key or #key<20 then cb(nil,"Invalid API key");return end
    local prompt=string.format(
        "You are the most savage Roblox rap battle roaster. Write exactly %d rap lines roasting: %s\n"..
        "Rules: each line on its own line, under 100 chars, funny roast, no numbers/bullets, "..
        "Roblox slang, rhyme where possible. Output ONLY the %d lines.",n,desc,n)
    local body=HttpService:JSONEncode({model="gpt-4o",max_tokens=600,messages={
        {role="system",content="You are a savage Roblox rap battle roaster."},
        {role="user",content=prompt}}})
    task.spawn(function()
        local ok,res=pcall(function()
            return req({Url="https://api.openai.com/v1/chat/completions",Method="POST",
                Headers={["Content-Type"]="application/json",["Authorization"]="Bearer "..key},Body=body})
        end)
        if not ok then cb(nil,"Request failed: "..tostring(res));return end
        pcall(function() res=HttpService:JSONDecode(res.Body) end)
        if res and res.error then cb(nil,"OpenAI: "..(res.error.message or "error"));return end
        if res and res.choices and res.choices[1] and res.choices[1].message then
            local lines={}
            for line in res.choices[1].message.content:gmatch("[^\n]+") do
                line=line:match("^%s*(.-)%s*$");if #line>2 then table.insert(lines,line) end
            end
            cb(lines,nil)
        else cb(nil,"Bad API response") end
    end)
end

