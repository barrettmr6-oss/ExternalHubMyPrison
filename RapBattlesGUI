        task.delay(0.5,function() Tw(ApiWrap,0.3,{BackgroundColor3=C.BG0}) end);return
    end
    if not desc or #desc<3 then setStatus("Describe the opponent first!",C.YELLOW,"⚠");return end
    rapping=true;GenBtn.Text="⏳   Generating..."
    Tw(GenBtn,0.1,{BackgroundColor3=C.BG3});ProgTrack.Visible=true
