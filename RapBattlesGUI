-- ── OPENAI API ───────────────────────────────────────────────────────────────
local function GenerateRap(apiKey, description, numLines, callback)
    local requestFunc = (syn and syn.request)
        or (http and http.request) or (request) or nil

    if not requestFunc then
        callback(nil, "Executor doesn't support HTTP (try Synapse X, KRNL, Fluxus)")
        return
    end
    if not apiKey or #apiKey < 20 then
        callback(nil, "Drop a valid OpenAI API key first")
        return
    end

    local prompt = string.format(
        "You are the most savage Roblox rap battle roaster alive. "..
        "Write exactly %d short rap lines roasting this Roblox avatar: %s\n\n"..
        "Rules:\n- Each line on its own line\n- Under 100 chars per line\n"..
        "- Funny and roast-focused\n- No numbers or bullets, just the lines\n"..
        "- Roblox slang and references\n- Rhyme where possible\n"..
        "Output ONLY the %d lines, nothing else.",
        numLines, description, numLines
    )

    local body = HttpService:JSONEncode({
        model = "gpt-4o",
        max_tokens = 600,
        messages = {
            {role = "system", content = "You are a savage Roblox rap battle roaster."},
            {role = "user",   content = prompt}
        }
    })

    task.spawn(function()
        local ok, res = pcall(function()
            return requestFunc({
                Url    = "https://api.openai.com/v1/chat/completions",
                Method = "POST",
                Headers = {
                    ["Content-Type"]  = "application/json",
                    ["Authorization"] = "Bearer "..apiKey,
                },
                Body = body
            })
        end)

        if not ok then callback(nil, "Request failed: "..tostring(res)); return end

        pcall(function() res = HttpService:JSONDecode(res.Body) end)
        if res and res.error then
            callback(nil, "OpenAI: "..(res.error.message or "error")); return
        end

        if res and res.choices and res.choices[1] and res.choices[1].message then
            local text  = res.choices[1].message.content or ""
            local lines = {}
            for line in text:gmatch("[^\n]+") do
                line = line:match("^%s*(.-)%s*$")
                if #line > 2 then table.insert(lines, line) end
            end
            callback(lines, nil)
        else
            callback(nil, "Bad API response — check key & executor HTTP")
        end
    end)
end

