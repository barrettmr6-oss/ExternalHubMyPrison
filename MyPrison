    leftBar.Parent           = bg
    AddCorner(leftBar, 2)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size                  = UDim2.new(0, 32, 1, 0)
    iconLbl.Position              = UDim2.new(0, 8, 0, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text                  = icon
    iconLbl.TextSize              = 18
    iconLbl.Font                  = Enum.Font.GothamBold
    iconLbl.TextColor3            = col
    iconLbl.Parent                = bg

    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size                  = UDim2.new(1, -48, 1, 0)
    msgLbl.Position              = UDim2.new(0, 44, 0, 0)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Font                  = Enum.Font.GothamMedium
    msgLbl.TextColor3            = C.text
    msgLbl.TextSize              = 13
    msgLbl.TextXAlignment        = Enum.TextXAlignment.Left
    msgLbl.TextWrapped           = true
    msgLbl.Text                  = msg
    msgLbl.Parent                = bg

    -- Fade in
    bg.BackgroundTransparency = 1
    Tween(bg, {BackgroundTransparency = 0.05}, 0.25)

    -- Auto-dismiss after 3s
    task.delay(3.2, function()
        if bg and bg.Parent then
            Tween(bg, {BackgroundTransparency = 1}, 0.3)
            task.delay(0.35, function()
                if bg and bg.Parent then bg:Destroy() end
            end)
        end
    end)
end

