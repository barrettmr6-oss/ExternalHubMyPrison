        lbl.TextColor3            = C.textDim
        lbl.TextSize              = 11
        lbl.TextXAlignment        = Enum.TextXAlignment.Left
        lbl.Text                  = line
        lbl.ZIndex                = 5
        lbl.Parent                = card
    end
end

-- Toggle row
local function MakeToggle(parent, icon, label, desc, stateKey, color, order)
    color = color or C.accent

    local row = Instance.new("Frame")
    row.Name             = "Toggle_" .. label
    row.Size             = UDim2.new(1, 0, 0, 64)
    row.BackgroundColor3 = C.bg3
    row.BorderSizePixel  = 0
    row.LayoutOrder      = order
    row.ZIndex           = 4
    row.Parent           = parent
    AddCorner(row, 10)
    local rowStroke = AddStroke(row, C.accentOff, 1, 0.35)

    -- Icon wrapper
    local iconWrap = Instance.new("Frame")
    iconWrap.Size             = UDim2.new(0, 42, 0, 42)
    iconWrap.Position         = UDim2.new(0, 10, 0.5, -21)
    iconWrap.BackgroundColor3 = C.accentDim
    iconWrap.BorderSizePixel  = 0
    iconWrap.ZIndex           = 5
    iconWrap.Parent           = row
    AddCorner(iconWrap, 9)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size                  = UDim2.new(1, 0, 1, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text                  = icon
    iconLbl.TextSize              = 20
    iconLbl.ZIndex                = 6
    iconLbl.Parent                = iconWrap

    -- Labels
    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size                  = UDim2.new(1, -118, 0, 20)
    nameLbl.Position              = UDim2.new(0, 62, 0, 11)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Font                  = Enum.Font.GothamBold
    nameLbl.TextColor3            = C.text
    nameLbl.TextSize              = 13
    nameLbl.TextXAlignment        = Enum.TextXAlignment.Left
    nameLbl.Text                  = label
    nameLbl.ZIndex                = 5
    nameLbl.Parent                = row

    local descLbl = Instance.new("TextLabel")
    descLbl.Size                  = UDim2.new(1, -118, 0, 30)
    descLbl.Position              = UDim2.new(0, 62, 0, 32)
    descLbl.BackgroundTransparency = 1
    descLbl.Font                  = Enum.Font.Gotham
    descLbl.TextColor3            = C.textDim
    descLbl.TextSize              = 10
    descLbl.TextXAlignment        = Enum.TextXAlignment.Left
    descLbl.TextWrapped           = true
    descLbl.Text                  = desc
    descLbl.ZIndex                = 5
    descLbl.Parent                = row

    -- Pill toggle
    local pillBg = Instance.new("Frame")
    pillBg.Size             = UDim2.new(0, 48, 0, 26)
    pillBg.Position         = UDim2.new(1, -60, 0.5, -13)
    pillBg.BackgroundColor3 = C.accentOff
    pillBg.BorderSizePixel  = 0
    pillBg.ZIndex           = 5
    pillBg.Parent           = row
    AddCorner(pillBg, 13)

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 20, 0, 20)
    knob.Position         = UDim2.new(0, 3, 0.5, -10)
    knob.BackgroundColor3 = C.knobOff
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 6
    knob.Parent           = pillBg
    AddCorner(knob, 10)

    local function Refresh()
        local on = State[stateKey]
        Tween(pillBg,   {BackgroundColor3 = on and color       or C.accentOff},  0.2)
        Tween(knob,     {Position = on
                            and UDim2.new(1, -23, 0.5, -10)
                            or  UDim2.new(0,   3, 0.5, -10)},                    0.2)
        Tween(knob,     {BackgroundColor3 = on and C.knobOn    or C.knobOff},    0.2)
        Tween(rowStroke,{Color            = on and color       or C.accentOff},  0.2)
        Tween(iconWrap, {BackgroundColor3 = on and C.accentDim or C.accentDim},  0.2)
    end

    -- Full-row clickable hitbox
    local hitbox = Instance.new("TextButton")
    hitbox.Size                  = UDim2.new(1, 0, 1, 0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text                  = ""
    hitbox.ZIndex                = 7
    hitbox.Parent                = row

    hitbox.MouseButton1Click:Connect(function()
        State[stateKey] = not State[stateKey]
        Refresh()
        local on = State[stateKey]
        Notify(label .. (on and "  ›  ON" or "  ›  OFF"), on and color or C.red, icon)
    end)

    hitbox.MouseEnter:Connect(function()
        Tween(row, {BackgroundColor3 = Color3.fromRGB(26, 36, 28)}, 0.12)
    end)
    hitbox.MouseLeave:Connect(function()
        Tween(row, {BackgroundColor3 = C.bg3}, 0.12)
    end)

    Refresh()
end

