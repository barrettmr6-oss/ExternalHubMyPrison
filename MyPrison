-- DRAG (via Header)
-- ══════════════════════════════════════════
local dragging  = false
local dragStart = nil
local winStart  = nil

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging  = true
        dragStart = input.Position
        winStart  = Main.Position
    end
end)

Header.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        local newX = winStart.X.Offset + delta.X
        local newY = winStart.Y.Offset + delta.Y
        Main.Position   = UDim2.new(winStart.X.Scale, newX, winStart.Y.Scale, newY)
        Shadow.Position = UDim2.new(winStart.X.Scale, newX - 6, winStart.Y.Scale, newY - 4)
    end
end)

